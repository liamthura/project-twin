# MyGist Frontend Environment Variables
# Copy to .env.local for local development

# Backend API URL (optional - defaults to /api which uses proxy in dev)
# Set this to your deployed backend URL in production
# VITE_API_URL=https://your-mygist-server.coolify.app/api

# Default API token (optional - can also be configured in the UI)
# VITE_API_TOKEN=your-secret-token
