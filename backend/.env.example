# =============================================================================
# MyGist MCP Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# REQUIRED IN PRODUCTION
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MYGIST_API_TOKEN=

# OPTIONAL - Data directory path (default: ../mygist_data)
# In Docker, this should be /app/data (mounted volume)
# PERSONA_DATA_DIR=/app/data

# OPTIONAL - Server settings
# PORT=8000
# HOST=0.0.0.0

# OPTIONAL - Debug mode (enables verbose logging)
# DEBUG=false

# OPTIONAL - Transport mode (http or stdio)
# MCP_TRANSPORT=http
